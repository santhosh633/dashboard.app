function verifyResetAndUpdate() {
    const email = document.getElementById('forgotEmail').value.trim().toLowerCase();
    const code = document.getElementById('resetOTP').value.trim();
    const newPass = document.getElementById('newPassword').value;
    
    if (!code || !newPass) {
        showToast('Please fill all fields', 'error');
        return;
    }
    
    if (newPass.length < 6) {
        showToast('Password must be at least 6 characters', 'error');
        return;
    }
    
    const resetTokens = JSON.parse(localStorage.getItem(RESET_TOKENS_KEY) || '{}');
    const resetData = resetTokens[email];
    
    if (!resetData || resetData.code !== code) {
        showToast('Invalid or expired code', 'error');
        return;
    }
    
    if (Date.now() > resetData.expiry) {
        showToast('Code expired. Please request a new one.', 'error');
        return;
    }
    
    const users = JSON.parse(localStorage.getItem(USERS_KEY) || '[]');
    const user = users.find(u => u.email.toLowerCase() === email);
    
    if (user) {
        user.password = hashPassword(newPass);
        localStorage.setItem(USERS_KEY, JSON.stringify(users));
    }
    
    delete resetTokens[email];
    localStorage.setItem(RESET_TOKENS_KEY, JSON.stringify(resetTokens));
    
    document.getElementById('resetOTP').value = '';
    document.getElementById('newPassword').value = '';
    
    showToast('Password updated successfully!');
    toggleAuth('login');
