    if (id === '__overview__') {
        document.getElementById('overviewTabBtn').classList.add('active');
    } else if (id === '__attendance__') {
        document.getElementById('attendanceTabBtn').classList.add('active');
    } else {
        const tab = document.getElementById('stab-' + id);
        if (tab) tab.classList.add('active');
    }
}

function renderTabsBar() {
    const list = document.getElementById('sheetTabsList');
    let html = '';
    state.sheets.forEach(s => {
        html += `
            <div class="sheet-tab ${s.id === state.activeSheet ? 'active' : ''}" id="stab-${s.id}" onclick="switchSheet('${s.id}')">
                <div class="w-2 h-2 rounded-full" style="background:${s.color}"></div>
                ${sanitizeHTML(s.name)}
                ${s.processed ? `<span class="text-xs opacity-60 ml-2">${s.counts.total}</span>` : ''}
                ${currentUser?.role !== 'public' ? `<span class="tab-close" onclick="event.stopPropagation(); deleteSheet('${s.id}')" title="Delete project">&times;</span>` : ''}
            </div>
        `;
    });
    list.innerHTML = html;
}

function deleteSheet(id) {
    if (!confirm('Delete this project? This cannot be undone.')) return;
    state.sheets = state.sheets.filter(s => s.id !== id);
    const panel = document.getElementById('panel-' + id);
    if (panel) panel.remove();
    switchSheet('__overview__');
    saveState();
    refreshPagesAnalytics();
}

function clearSheetData(id) {
    if (!confirm('Clear all data from this project?')) return;
    const sheet = state.sheets.find(s => s.id === id);
    if (!sheet) return;
    sheet.csvData = { headers: [], rows: [] };
    sheet.userStats = {};
    sheet.processed = false;
    sheet.counts = { done: 0, inProcess: 0, work: 0, total: 0, users: 0, totalPages: 0 };
    sheet.columnMap = null;
    processSheetData(sheet);
    saveState();
    refreshPagesAnalytics();
    showToast('Data cleared');
}

function openUploadModal(sheetId) {
    const modal = document.getElementById('uploadModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Only attach listeners once securely
    if (!uploadListenersAttached) {
        const zone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        
        zone.addEventListener('dragover', (e) => {
            e.preventDefault();
            zone.classList.add('drag-over');
        });
        
        zone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            zone.classList.remove('drag-over');
        });
        
        zone.addEventListener('drop', (e) => {
            e.preventDefault();
            zone.classList.remove('drag-over');
            if (e.dataTransfer.files.length > 0) {
                processFile(e.dataTransfer.files[0]);
            }
        });
        
        fileInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                processFile(this.files[0]);
                // Fixed Bug 3: Automatically clear the input's evaluated value cleanly preventing the same file blocking upload
                this.value = '';
            }
        });
        
        uploadListenersAttached = true;
    }
    
    // Update dropdown
    const select = document.getElementById('uploadTargetSheet');
    select.innerHTML = '<option value="__new__">+ Create new project</option>' + 
        state.sheets.map(s => `<option value="${s.id}" ${s.id === sheetId ? 'selected' : ''}>${sanitizeHTML(s.name)}</option>`).join('');
}

function closeUploadModal() {
    document.getElementById('uploadModal').classList.add('hidden');
    document.getElementById('uploadModal').classList.remove('flex');
}

function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    const msgEl = document.getElementById('toastMsg');
    msgEl.textContent = msg;
    
    toast.className = 'toast ' + (type === 'error' ? 'error' : '');
    const icon = toast.querySelector('i');
    if (icon) {
        icon.className = type === 'error' ? 'fas fa-exclamation-circle text-red-400 text-xl' : 'fas fa-check-circle text-green-400 text-xl';
    }
    
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
}

function renderAll() {
    renderTabsBar();
    refreshOverview();
    refreshPagesAnalytics();
    state.sheets.forEach(s => { if (s.processed) processSheetData(s); });
    if (state.aiInsights.length) renderAIInsights();
    if (state.activeSheet === '__attendance__') renderAttendance();
}
</script>
</body>
</html>