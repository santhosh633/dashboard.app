function openAttendanceModal() {
    document.getElementById('attendanceModal').classList.remove('hidden');
    document.getElementById('attendanceModal').classList.add('flex');
}

function closeAttendanceModal() {
    document.getElementById('attendanceModal').classList.add('hidden');
    document.getElementById('attendanceModal').classList.remove('flex');
}

function setupAttendanceDrop() {
    const zone = document.getElementById('attendanceDropZone');
    if (!zone) return;
    
    zone.addEventListener('click', () => document.getElementById('attendanceFileInput').click());
    
    ['dragenter', 'dragover'].forEach(e => {
        zone.addEventListener(e, (ev) => {
            ev.preventDefault();
            zone.classList.add('drag-over');
        });
    });
    
    ['dragleave', 'drop'].forEach(e => {
        zone.addEventListener(e, (ev) => {
            ev.preventDefault();
            zone.classList.remove('drag-over');
        });
    });
    
    zone.addEventListener('drop', e => {
        if (e.dataTransfer.files.length) {
            processAttendanceFile(e.dataTransfer.files[0]);
        }
    });
}

function handleAttendanceFileSelect(input) {
    if (input.files && input.files[0]) {
        processAttendanceFile(input.files[0]);
        input.value = ''; // Reset to ensure future uploads work
    }
}

function processAttendanceFile(file) {
    if (!file.name.endsWith('.csv')) {
        showToast('Please upload a CSV file', 'error');
        return;
    }
    
    // Leverage PapaParse for accurate array translations securely
    Papa.parse(file, {
        header: true,
        skipEmptyLines: true,
        complete: function(results) {
            parseAttendanceData(results.data, results.meta.fields);
        },
        error: function(err) {
            console.error(err);
            showToast('Error reading CSV file', 'error');
        }
    });
}

function parseAttendanceData(rows, headers) {
    if (rows.length === 0) {
        showToast('CSV file is empty', 'error');
        return;
    }
    
    const nameCol = headers.find(h => h.toLowerCase().includes('name')) || headers[0];
    const dateCol = headers.find(h => h.toLowerCase().includes('date')) || headers[1];
    const statusCol = headers.find(h => h.toLowerCase().includes('status')) || headers[2];
    const timeCol = headers.find(h => h.toLowerCase().includes('time')) || headers[3];
    
    const newRecords = [];
    rows.forEach(row => {
        const name = row[nameCol]?.trim();
        const status = (row[statusCol] || '').toLowerCase();
        const date = row[dateCol] || new Date().toISOString().split('T')[0];
        const time = row[timeCol] || '';
        
        if (name) {
            newRecords.push({
                name,
                date,
                status: status.includes('present') ? 'Present' : 
                        status.includes('half') ? 'Half Day' : 'Absent',
                time,
                timestamp: Date.now()
            });
        }
    });
    
    if (newRecords.length === 0) {
        showToast('No valid records found', 'error');
        return;
    }
    
    state.attendance = [...state.attendance, ...newRecords];
    saveState();
    closeAttendanceModal();
    showToast(`Uploaded ${newRecords.length} attendance records`);
    
    if (state.activeSheet === '__attendance__') {
        renderAttendance();
    }
}

function renderAttendance() {
    const container = document.getElementById('attendanceRows');
    const emptyState = document.getElementById('attendanceEmpty');
    const contentState = document.getElementById('attendanceContent');
    const statsDiv = document.getElementById('attendanceStats');
    
    if (state.attendance.length === 0) {
        emptyState.classList.remove('hidden');
        contentState.classList.add('hidden');
        statsDiv.classList.add('hidden');
        return;
    }
    
    emptyState.classList.add('hidden');
    contentState.classList.remove('hidden');
    statsDiv.classList.remove('hidden');
    
    const byDate = {};
    state.attendance.forEach(record => {
        if (!byDate[record.date]) byDate[record.date] = [];
        byDate[record.date].push(record);
    });
    
    const latestDate = Object.keys(byDate).sort().pop() || new Date().toISOString().split('T')[0];
    const todayRecords = byDate[latestDate] || [];
    
    document.getElementById('att-date').textContent = sanitizeHTML(latestDate);
    
    const present = todayRecords.filter(r => r.status === 'Present').length;
    const absent = todayRecords.filter(r => r.status === 'Absent').length;
    const half = todayRecords.filter(r => r.status === 'Half Day').length;
    
    document.getElementById('att-present').textContent = present;
    document.getElementById('att-absent').textContent = absent;
    document.getElementById('att-half').textContent = half;
    document.getElementById('att-total').textContent = todayRecords.length;
    
    container.innerHTML = todayRecords.map((record, idx) => {
        const statusClass = record.status === 'Present' ? 'attendance-present' : 
                           record.status === 'Absent' ? 'attendance-absent' : 'attendance-half';
        return `
            <div class="grid grid-cols-4 gap-4 p-4 items-center hover:bg-white/5">
                <div class="text-gray-500">${idx + 1}</div>
                <div class="font-medium">${sanitizeHTML(record.name)}</div>
                <div><span class="attendance-status ${statusClass}">${record.status}</span></div>
                <div class="text-gray-400 text-sm">${sanitizeHTML(record.time || '--:--')}</div>
            </div>
        `;
    }).join('');
}

