// ================= CSV PROCESSING =================
function processFile(file) {
    if (!file.name.endsWith('.csv')) {
        showToast('Please upload a CSV file', 'error');
        return;
    }
    
    showToast('Parsing CSV securely...', 'success');
    const targetId = document.getElementById('uploadTargetSheet').value;
    
    // Fixed Bug 4: Implemented Papa Parse for stable and robust CSV reading mapping
    Papa.parse(file, {
        header: true,
        skipEmptyLines: true,
        complete: async function(results) {
            await parseCSVData(results.data, results.meta.fields, targetId);
        },
        error: function(err) {
            console.error('Papa Parse error:', err);
            showToast('Error reading file structure', 'error');
        }
    });
}

async function parseCSVData(rows, headers, targetId) {
    let sheet;
    if (targetId === '__new__') {
        sheet = addBlankSheet();
    } else {
        sheet = state.sheets.find(s => s.id === targetId);
    }
    
    if (!sheet) return;
    
    if (rows.length === 0) {
        showToast('No data rows found in CSV', 'error');
        return;
    }
    
    sheet.csvData = { headers, rows };
    sheet.columnMap = await getColumnMapping(headers, rows);
    
    await analyzeData(sheet);
    processSheetData(sheet);
    
    closeUploadModal();
    switchSheet(sheet.id);
    saveState();
    showToast(`Data uploaded! AI detected: ${Object.values(sheet.columnMap).filter(Boolean).join(', ')}`);
    
    refreshPagesAnalytics();
    
    if (currentUser?.role !== 'public') {
        generateAIInsights(sheet);
    }
}

async function analyzeData(sheet) {
    const map = sheet.columnMap || {};
    const rows = sheet.csvData.rows;
    
    const userCol = map.user || sheet.csvData.headers[0];
    const statusCol = map.status || sheet.csvData.headers.find(h => h.toLowerCase().includes('status')) || sheet.csvData.headers[1];
    const pageCol = map.page || sheet.csvData.headers.find(h => h.toLowerCase().includes('page')) || sheet.csvData.headers[2];
    const qcCol = map.qc;
    const dateCol = map.date;
    
    sheet.userStats = {};
    sheet.counts = { done: 0, inProcess: 0, work: 0, total: 0, users: 0, totalPages: 0 };
    sheet.hasQC = !!qcCol;
    
    rows.forEach(row => {
        const user = row[userCol]?.trim();
        if (!user) return;
        
        const status = (row[statusCol] || '').toLowerCase();
        const pages = parseInt(row[pageCol]) || 0;
        const qcFiles = qcCol ? (parseInt(row[qcCol]) || 0) : 0;
        
        if (!sheet.userStats[user]) {
            sheet.userStats[user] = {
                name: user,
                done: 0, inProcess: 0, work: 0, total: 0,
                pagesDone: 0,
                pagesTotal: 0,
                qcFiles: 0,
                lastActive: null,
                dates: []
            };
        }
        
        const userStat = sheet.userStats[user];

        // Fixed Bug 2: Ensured Total Pages count the whole assigned capacity, not just completely done items
        sheet.counts.totalPages += pages;
        userStat.pagesTotal += pages;
        
        if (status.includes('done') || status.includes('complete') || status.includes('finish') || 
            status.includes('closed') || status.includes('resolved')) {
            userStat.done++;
            userStat.pagesDone += pages;
            sheet.counts.done++;
        } else if (status.includes('process') || status.includes('progress') || status.includes('ongoing') || 
                   status.includes('inprocess') || status.includes('active')) {
            userStat.inProcess++;
            sheet.counts.inProcess++;
        } else {
            userStat.work++;
            sheet.counts.work++;
        }
        
        if (sheet.isR365 && qcCol) {
            userStat.qcFiles += qcFiles;
        }
        
        if (dateCol && row[dateCol]) {
            const d = new Date(row[dateCol]);
            if (!isNaN(d)) {
                userStat.dates.push(d);
                if (!userStat.lastActive || d > userStat.lastActive) {
                    userStat.lastActive = d;
                }
            }
        }
        
        userStat.total++;
        sheet.counts.total++;
    });
    
    sheet.counts.users = Object.keys(sheet.userStats).length;
    sheet.processed = true;
}

