async function runAIAgent() {
    const input = document.getElementById('aiInput');
    const query = input.value.trim();
    const chatBox = document.getElementById('aiChatBox');
    
    if (!query) return;
    
    // Sanitize user input before displaying
    const safeQuery = sanitizeHTML(query);
    const userMsg = document.createElement('div');
    userMsg.className = 'ai-message user';
    userMsg.innerHTML = `<i class="fas fa-user mr-2"></i>${safeQuery}`;
    chatBox.appendChild(userMsg);
    
    input.value = '';
    chatBox.scrollTop = chatBox.scrollHeight;
    
    const loadingMsg = document.createElement('div');
    loadingMsg.className = 'ai-message bot';
    loadingMsg.innerHTML = '<span class="loading-spinner"></span> AI analyzing...';
    chatBox.appendChild(loadingMsg);
    chatBox.scrollTop = chatBox.scrollHeight;
    
    try {
        const response = await processAIQuery(query);
        loadingMsg.remove();
        
        const botMsg = document.createElement('div');
        botMsg.className = 'ai-message bot';
        botMsg.innerHTML = `<i class="fas fa-robot mr-2 text-green-400"></i>${sanitizeHTML(response.text)}`;
        chatBox.appendChild(botMsg);
        
        if (response.chart) {
            generateAIChart(response.chartType || 'bar', response.chartData);
        }
    } catch (e) {
        loadingMsg.remove();
        const errorMsg = document.createElement('div');
        errorMsg.className = 'ai-message bot';
        errorMsg.innerHTML = `<i class="fas fa-exclamation-circle mr-2 text-red-400"></i>Sorry, I encountered an error processing your request.`;
        chatBox.appendChild(errorMsg);
    }
    
    chatBox.scrollTop = chatBox.scrollHeight;
}

async function processAIQuery(query) {
    try {
        const loadedSheets = state.sheets.filter(s => s.processed);
        const response = await fetch('/api/chat', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                query: query,
                sheets: loadedSheets
            })
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        return data;
    } catch (e) {
        console.error("Backend AI processing failed:", e);
        return {
            text: `❌ Could not connect to Python backend! Error: ${e.message}. Make sure your backend server is running.`
        };
    }
}

function generateAIChart(type = 'bar', customData = null) {
    const ctx = document.getElementById('aiChartCanvas');
    if (!ctx) return;
    
    if (currentChart && typeof currentChart.destroy === 'function') {
        currentChart.destroy();
        currentChart = null;
    }
    
    let labels, data, label;
    
    if (customData) {
        labels = customData.labels;
        data = customData.data;
        label = 'Pages Completed';
    } else {
        const loaded = state.sheets.filter(s => s.processed);
        const userStats = {};
        
        loaded.forEach(sheet => {
            Object.values(sheet.userStats).forEach(user => {
                if (!userStats[user.name]) {
                    userStats[user.name] = 0;
                }
                userStats[user.name] += user.pagesDone || user.done;
            });
        });
        
        const sorted = Object.entries(userStats).sort((a, b) => b[1] - a[1]).slice(0, 6);
        labels = sorted.map(x => x[0]);
        data = sorted.map(x => x[1]);
        label = 'Performance Score';
    }
    
    const config = {
        type: type,
        data: {
            labels: labels,
            datasets: [{
                label: label,
                data: data,
                backgroundColor: [
                    'rgba(0, 120, 212, 0.8)',
                    'rgba(16, 185, 129, 0.8)',
                    'rgba(245, 158, 11, 0.8)',
                    'rgba(139, 92, 246, 0.8)',
                    'rgba(236, 72, 153, 0.8)',
                    'rgba(59, 130, 246, 0.8)'
                ],
                borderColor: [
                    'rgba(0, 120, 212, 1)',
                    'rgba(16, 185, 129, 1)',
                    'rgba(245, 158, 11, 1)',
                    'rgba(139, 92, 246, 1)',
                    'rgba(236, 72, 153, 1)',
                    'rgba(59, 130, 246, 1)'
                ],
                borderWidth: 2,
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    labels: { color: '#e2e8f0' }
                }
            },
            scales: type === 'bar' ? {
                y: {
                    beginAtZero: true,
                    ticks: { color: '#94a3b8' },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                },
                x: {
                    ticks: { color: '#94a3b8' },
                    grid: { display: false }
                }
            } : {}
        }
    };
    
    try {
        currentChart = new Chart(ctx, config);
        // showToast('AI Chart generated successfully!');
    } catch (e) {
        console.error('Chart error:', e);
        showToast('Error generating chart', 'error');
    }
}

// ================= PAGES ANALYTICS =================
function refreshPagesAnalytics() {
    const loaded = state.sheets.filter(s => s.processed);
    
    let totalPages = 0;
    let donePages = 0;
    let progressPages = 0;
    let pendingPages = 0;
    const userPageStats = {};
    let totalUsers = new Set();
    
    loaded.forEach(sheet => {
        totalPages += sheet.counts.totalPages || 0;
        
        Object.values(sheet.userStats).forEach(user => {
            totalUsers.add(user.name);
            
            if (!userPageStats[user.name]) {
                userPageStats[user.name] = {
                    name: user.name,
                    done: 0,
                    inProgress: 0,
                    pending: 0,
                    total: 0
                };
            }
            
            userPageStats[user.name].done += user.pagesDone || 0;
            userPageStats[user.name].inProgress += Math.round((user.inProcess || 0) * ((user.pagesDone || 0) / Math.max(user.done || 1, 1)));
            userPageStats[user.name].pending += Math.round((user.work || 0) * ((user.pagesDone || 0) / Math.max(user.done || 1, 1)));
            userPageStats[user.name].total += user.pagesTotal !== undefined ? user.pagesTotal : (user.pagesDone || 0);
        });
        
        const totalTasks = sheet.counts.total || 1;
        const avgPagesPerTask = (sheet.counts.totalPages || 0) / totalTasks;
        
        donePages += sheet.counts.done * avgPagesPerTask;
        progressPages += sheet.counts.inProcess * avgPagesPerTask;
        pendingPages += sheet.counts.work * avgPagesPerTask;
    });
    
    document.getElementById('total-pages-count').textContent = Math.round(totalPages).toLocaleString();
    document.getElementById('pages-done-count').textContent = Math.round(donePages).toLocaleString();
    document.getElementById('pages-progress-count').textContent = Math.round(progressPages).toLocaleString();
    document.getElementById('pages-pending-count').textContent = Math.round(pendingPages).toLocaleString();
    
    const avgPages = totalUsers.size > 0 ? Math.round(totalPages / totalUsers.size) : 0;
    document.getElementById('pages-avg-count').textContent = avgPages.toLocaleString();
    
    const completionRate = totalPages > 0 ? Math.round((donePages / totalPages) * 100) : 0;
    document.getElementById('pages-completion-rate').textContent = completionRate + '%';
    document.getElementById('pages-progress-bar').style.width = completionRate + '%';
    
    const topContributors = Object.values(userPageStats)
        .sort((a, b) => b.total - a.total)
        .slice(0, 4);
    
    const container = document.getElementById('top-pages-contributors');
    if (topContributors.length === 0) {
        container.innerHTML = '<div class="col-span-4 text-gray-500 text-sm text-center py-4">No page data available yet. Upload CSV with Page Count column.</div>';
    } else {
        container.innerHTML = topContributors.map(user => {
            const percentage = totalPages > 0 ? ((user.total / totalPages) * 100).toFixed(1) : 0;
            return `
                <div class="pages-stat-card">
                    <div class="flex items-center gap-2 mb-2">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-xs font-bold text-white">
                            ${sanitizeHTML(user.name.slice(0, 2).toUpperCase())}
                        </div>
                        <div class="truncate flex-1">
                            <div class="text-sm font-medium truncate">${sanitizeHTML(user.name)}</div>
                        </div>
                    </div>
                    <div class="text-lg font-bold text-white mb-1">${Math.round(user.total).toLocaleString()}</div>
                    <div class="text-xs text-gray-400">${percentage}% of total</div>
                    <div class="mt-2 h-1.5 bg-gray-700/50 rounded-full overflow-hidden">
                        <div class="h-full bg-blue-500 rounded-full" style="width: ${percentage}%"></div>
                    </div>
                </div>
            `;
        }).join('');
    }
}

