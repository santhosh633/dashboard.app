<script>
// ================= SECURITY UTILITIES =================
function sanitizeHTML(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
}

function escapeRegExp(string) {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// Simple hash function for passwords (better than plaintext)
function hashPassword(password) {
    let hash = 0;
    for (let i = 0; i < password.length; i++) {
        const char = password.charCodeAt(i);
        hash = ((hash << 5) - hash) + char;
        hash = hash & hash;
    }
    return hash.toString(16) + '_hashed';
}

// ================= STATE =================
const STORAGE_KEY = 'axximum_data_v2';
const AUTH_KEY = 'axximum_auth';
const PENDING_USERS_KEY = 'axximum_pending_users';
const RESET_TOKENS_KEY = 'axximum_reset_tokens';
const BROADCAST_CHANNEL = 'axximum_live_updates';
const USERS_KEY = 'axximum_users';

let currentUser = null;
let broadcastChannel = null;
let state = {
    sheets: [],
    activeSheet: '__overview__',
    nextId: 1,
    aiInsights: [],
    attendance: [],
    columnMap: {}
};

let currentChart = null;
let uploadListenersAttached = false;

// ================= INIT =================
document.addEventListener('DOMContentLoaded', async () => {
    initBroadcastChannel();
    setupAttendanceDrop();
    
    // Asynchronously load state from indexedDB
    if (!(await loadState())) {
        state.nextId = 1;
        state.attendance = [];
    }
    
    // Auth automatically triggers renderAll after loading state is complete
    checkAuth();
});

// ================= AI COLUMN DETECTION =================
function detectColumns(headers) {
    const map = {};
    
    headers.forEach(h => {
        const key = h.toLowerCase().replace(/[_\s-]/g, '');
        
        if (key.includes('user') || key.includes('name') || key.includes('employee') || 
            key.includes('person') || key.includes('staff') || key.includes('member')) {
            if (!map.user || key.length < map.user.length) {
                map.user = h;
            }
        }
        
        if (key.includes('status') || key.includes('state') || key.includes('progress') || 
            key.includes('condition') || key.includes('stage')) {
            map.status = h;
        }
        
        if (key.includes('page') || key.includes('count') || key.includes('pages') || 
            key.includes('total') || key.includes('volume') || key.includes('quantity')) {
            if (!map.page || key.includes('page')) {
                map.page = h;
            }
        }
        
        if (key.includes('qc') || key.includes('quality') || key.includes('files') || 
            key.includes('checked') || key.includes('approved')) {
            map.qc = h;
        }
        
        if (key.includes('date') || key.includes('time') || key.includes('created') || 
            key.includes('updated') || key.includes('timestamp')) {
            map.date = h;
        }
    });
    
    return map;
}

async function detectWithAI(headers, sampleData) {
    const map = {};
    
    const userCandidates = headers.filter((h, i) => {
        const l = h.toLowerCase();
        return l.includes('user') || l.includes('name') || l.includes('person') || i === 0;
    });
    if (userCandidates.length > 0) {
        map.user = userCandidates.find(h => h.toLowerCase().includes('user')) || 
                   userCandidates.find(h => h.toLowerCase().includes('name')) || 
                   userCandidates[0];
    }
    
    // Fixed Bug 1: Read by header key `h`, instead of integer index `i` on objects with string properties.
    const statusCol = headers.find(h => {
        const values = sampleData.slice(0, 5).map(row => row[h]?.toLowerCase());
        const hasStatusWords = values.some(v => 
            v && (v.includes('done') || v.includes('process') || v.includes('work') || 
                  v.includes('complete') || v.includes('pending'))
        );
        return hasStatusWords;
    });
    if (statusCol) map.status = statusCol;
    
    const pageCol = headers.find(h => {
        const values = sampleData.slice(0, 5).map(row => row[h]);
        const numericCount = values.filter(v => typeof v !== 'undefined' && !isNaN(parseInt(v))).length;
        const hasPageWord = h.toLowerCase().includes('page') || h.toLowerCase().includes('count');
        return (hasPageWord && numericCount >= 2) || (numericCount >= 4);
    });
    if (pageCol) map.page = pageCol;
    
    await new Promise(resolve => setTimeout(resolve, 500));
    
    return map;
}

async function getColumnMapping(headers, rows) {
    let map = detectColumns(headers);
    const sampleData = rows.slice(0, 10);
    
    if (!map.user || !map.status) {
        showToast('AI analyzing spreadsheet structure...', 'success');
        const aiMap = await detectWithAI(headers, sampleData);
        map = { ...map, ...aiMap };
    }
    
    if (!map.user) map.user = headers[0];
    if (!map.status) map.status = headers.find(h => h.toLowerCase().includes('status')) || headers[1];
    if (!map.page) map.page = headers.find(h => h.toLowerCase().includes('page')) || headers[2];
    
    return map;
}

// ================= AUTHENTICATION =================
function toggleAuth(mode) {
    const forms = ['loginForm', 'registerForm', 'forgotForm', 'resetPasswordForm', 'verifyForm'];
    forms.forEach(id => document.getElementById(id).classList.add('hidden'));
    
    if (mode === 'login') document.getElementById('loginForm').classList.remove('hidden');
    else if (mode === 'register') document.getElementById('registerForm').classList.remove('hidden');
    else if (mode === 'forgot') document.getElementById('forgotForm').classList.remove('hidden');
    else if (mode === 'reset') document.getElementById('resetPasswordForm').classList.remove('hidden');
    else if (mode === 'verify') document.getElementById('verifyForm').classList.remove('hidden');
}

function handleLogin() {
    const email = document.getElementById('loginEmail').value.trim().toLowerCase();
    const password = document.getElementById('loginPassword').value;
    const hashedInput = hashPassword(password);
    
    if (email === 'demo@axximum.com' && password === 'demo123') {
        currentUser = { name: 'Demo Admin', email: email, role: 'admin', verified: true };
        localStorage.setItem(AUTH_KEY, JSON.stringify(currentUser));
        enterDashboard();
        showToast('Welcome back, Admin!');
        return;
    }
    
    const users = JSON.parse(localStorage.getItem(USERS_KEY) || '[]');
    const user = users.find(u => 
        u.email.toLowerCase() === email && 
        u.password === hashedInput
    );
    
    if (user) {
        if (!user.verified) {
            showToast('Please verify your email first', 'error');
            
            const otp = Math.floor(100000 + Math.random() * 900000).toString();
