<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Axximum — AI-Powered Project Analytics</title>
    <!-- Dependencies -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/localforage/1.10.0/localforage.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        * { font-family: 'Inter', sans-serif; box-sizing: border-box; }

        :root {
            --axx-blue: #0078d4;
            --axx-light: #60a5fa;
            --axx-dark: #1e3a5f;
        }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            color: #e2e8f0;
            margin: 0;
        }

        /* Missing Logo CSS */
        .axximum-header { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
        }
        .logo-icon-container { 
            position: relative; 
            width: 40px; 
            height: 40px; 
            flex-shrink: 0;
        }
        .logo-square { 
            width: 24px; 
            height: 24px; 
            background: var(--axx-blue); 
            border-radius: 6px; 
            position: absolute; 
            top: 0; 
            left: 0; 
        }
        .logo-circle { 
            width: 20px; 
            height: 20px; 
            background: var(--axx-light); 
            border-radius: 50%; 
            position: absolute; 
            bottom: 0; 
            right: 0; 
        }
        .brand-text { 
            display: flex; 
            flex-direction: column; 
            line-height: 1.2;
        }
        .brand-name { 
            font-size: 1.5rem; 
            font-weight: 800; 
            color: white; 
            letter-spacing: -0.5px;
        }
        .brand-name span { 
            color: var(--axx-light); 
        }
        .brand-tagline { 
            font-size: 0.75rem; 
            color: #64748b; 
            margin-top: 2px;
        }

        .auth-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0a0f1d 0%, #1e293b 100%);
            position: relative;
        }
        
        .auth-bg {
            position: absolute;
            inset: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(0,120,212,0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(139,92,246,0.1) 0%, transparent 50%);
        }
        
        .auth-card {
            background: rgba(30, 41, 59, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0,120,212,0.3);
            border-radius: 24px;
            padding: 48px;
            width: 90%;
            max-width: 420px;
            position: relative;
            z-index: 10;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        }
        
        .auth-input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 10px;
            color: #e2e8f0;
            font-size: 0.95rem;
            transition: all 0.3s;
            margin-bottom: 16px;
        }
        
        .auth-input:focus {
            outline: none;
            border-color: var(--axx-blue);
            box-shadow: 0 0 0 3px rgba(0,120,212,0.15);
        }
        
        .auth-btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--axx-blue), var(--axx-light));
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,120,212,0.3);
        }
        
        .auth-btn.secondary {
            background: rgba(255,255,255,0.1);
            margin-top: 8px;
        }
        
        .auth-switch {
            text-align: center;
            margin-top: 24px;
            color: #64748b;
            font-size: 0.9rem;
        }
        
        .auth-switch span {
            color: var(--axx-light);
            cursor: pointer;
            font-weight: 600;
        }

        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
        }

        .live-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #10b981;
        }
        
        .pulse-dot {
            width: 6px;
            height: 6px;
            background: #10b981;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.8); }
        }

        .sheet-tabs-bar {
            display: flex;
            align-items: center;
            overflow-x: auto;
            scrollbar-width: none;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            background: rgba(15,23,42,0.5);
            padding: 0 1.5rem;
        }
        
        .sheet-tab {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 20px;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            white-space: nowrap;
            border-bottom: 2px solid transparent;
            color: #94a3b8;
            transition: all 0.2s;
            position: relative;
        }
        
        .sheet-tab:hover { color: #e2e8f0; background: rgba(0,120,212,0.08); }
        .sheet-tab.active {
            color: var(--axx-light);
            border-bottom-color: var(--axx-blue);
            background: rgba(0,120,212,0.1);
        }

        .add-sheet-btn {
            padding: 12px 16px;
            font-size: 20px;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
        }
        
        .add-sheet-btn:hover { color: var(--axx-light); }

        /* AI Chat Styles */
        .ai-chat-container {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(0,120,212,0.2);
            border-radius: 12px;
            padding: 16px;
            margin-top: 16px;
        }
        
        .ai-chat-box {
            max-height: 200px;
            overflow-y: auto;
            margin-bottom: 12px;
            padding: 8px;
            background: rgba(0,0,0,0.2);
            border-radius: 8px;
        }
        
        .ai-message {
            padding: 8px 12px;
            margin-bottom: 8px;
            border-radius: 8px;
            font-size: 0.9rem;
            line-height: 1.4;
            word-wrap: break-word;
        }
        
        .ai-message.user {
            background: rgba(0,120,212,0.2);
            margin-left: 20%;
            border-left: 3px solid var(--axx-blue);
        }
        
        .ai-message.bot {
            background: rgba(255,255,255,0.05);
            margin-right: 20%;
            border-left: 3px solid #10b981;
        }
        
        .ai-input-group {
            display: flex;
            gap: 8px;
        }
        
        .ai-input {
            flex: 1;
            padding: 10px 14px;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #e2e8f0;
            font-size: 0.9rem;
        }
        
        .ai-input:focus {
            outline: none;
            border-color: var(--axx-blue);
        }

        .ai-section {
            background: linear-gradient(135deg, rgba(0,120,212,0.1) 0%, rgba(139,92,246,0.05) 100%);
            border: 1px solid rgba(0,120,212,0.2);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 24px;
        }
        
        .ai-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            background: rgba(0,120,212,0.2);
            color: var(--axx-light);
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .insight-card {
            background: rgba(15, 23, 42, 0.6);
            border-left: 3px solid var(--axx-blue);
            padding: 16px;
            border-radius: 0 12px 12px 0;
            margin-top: 12px;
            transition: all 0.3s;
        }
        
        .insight-card:hover {
            transform: translateX(4px);
            border-left-width: 5px;
        }

        .stat-card, .pages-stat-card {
            background: rgba(30,41,59,0.6);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 20px;
            transition: all 0.3s;
        }
        
        .pages-stat-card {
            border-left: 4px solid transparent;
        }
        
        .stat-card:hover, .pages-stat-card:hover {
            border-color: rgba(0,120,212,0.3);
            transform: translateY(-2px);
        }

        .user-card {
            background: rgba(30,41,59,0.8);
            border: 1px solid rgba(0,120,212,0.2);
            border-radius: 16px;
            padding: 20px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }
        
        .user-card:hover {
            border-color: rgba(0,120,212,0.5);
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,120,212,0.15);
        }

        .progress-bar {
            height: 8px;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 8px;
        }
        
        .progress-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s;
        }

        .upload-zone {
            border: 2px dashed rgba(0,120,212,0.4);
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
            background: rgba(30,41,59,0.5);
        }
        
        .upload-zone:hover, .upload-zone.drag-over {
            border-color: var(--axx-blue);
            background: rgba(0,120,212,0.1);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--axx-blue), var(--axx-light));
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,120,212,0.3);
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(30,41,59,0.95);
            border: 1px solid rgba(0,120,212,0.5);
            padding: 16px 24px;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            transform: translateY(100px);
            opacity: 0;
            transition: all 0.3s;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .toast.show { transform: translateY(0); opacity: 1; }
        .toast.error { border-color: #ef4444; }

        .hidden { display: none !important; }
        
        .public-banner {
            background: linear-gradient(90deg, rgba(0,120,212,0.2), rgba(139,92,246,0.2));
            border: 1px solid rgba(0,120,212,0.3);
            border-radius: 8px;
            padding: 12px 20px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .tab-close {
            margin-left: 8px;
            opacity: 0.6;
            cursor: pointer;
            font-size: 1.2rem;
            line-height: 1;
        }
        .tab-close:hover { opacity: 1; color: #ef4444; }
        
        .completed-badge {
            position: absolute;
            top: 0;
            right: 0;
            background: #10b981;
            color: white;
            font-size: 0.7rem;
            padding: 4px 8px;
            border-bottom-left-radius: 8px;
        }
        
        .attendance-status {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .attendance-present { background: rgba(16, 185, 129, 0.2); color: #10b981; }
        .attendance-absent { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
        .attendance-half { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            vertical-align: middle;
            margin-right: 8px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.3);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(100, 116, 139, 0.5);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(100, 116, 139, 0.8);
        }
    </style>
</head>
<body>

<!-- ================= AUTHENTICATION PAGES ================= -->
<div id="authSection" class="auth-page">
    <div class="auth-bg"></div>
    
    <!-- Login Form -->
    <div id="loginForm" class="auth-card">
        <div class="axximum-header justify-center mb-8">
            <div class="logo-icon-container">
                <div class="logo-square"></div>
                <div class="logo-circle"></div>
            </div>
            <div class="brand-text">
                <div class="brand-name">axx<span>imum</span></div>
                <div class="brand-tagline">Where innovation meets intelligence</div>
            </div>
        </div>
        
        <h2 class="text-2xl font-bold mb-2 text-center">Welcome Back</h2>
        <p class="text-gray-400 text-center mb-6 text-sm">Sign in to manage projects</p>
        
        <input type="email" id="loginEmail" class="auth-input" placeholder="Email address" autocomplete="email">
        <input type="password" id="loginPassword" class="auth-input" placeholder="Password" autocomplete="current-password">
        
        <div class="flex justify-end mb-4">
            <button onclick="toggleAuth('forgot')" class="text-sm text-blue-400 hover:text-blue-300">
                Forgot password?
            </button>
        </div>
        
        <button class="auth-btn" onclick="handleLogin()">
            <i class="fas fa-sign-in-alt mr-2"></i> Sign In
        </button>
        
        <div class="auth-switch">
            Don't have an account? <span onclick="toggleAuth('register')">Sign up</span>
        </div>
        
        <div class="mt-6 pt-6 border-t border-white/10 text-center">
            <button onclick="continueAsPublic()" class="text-sm text-gray-400 hover:text-white transition">
                <i class="fas fa-eye mr-2"></i>Continue as Public Viewer
            </button>
        </div>
    </div>

    <!-- Register Form -->
    <div id="registerForm" class="auth-card hidden">
        <div class="axximum-header justify-center mb-8">
            <div class="logo-icon-container">
                <div class="logo-square"></div>
                <div class="logo-circle"></div>
            </div>
            <div class="brand-text">
                <div class="brand-name">axx<span>imum</span></div>
                <div class="brand-tagline">Where innovation meets intelligence</div>
            </div>
        </div>
        
        <h2 class="text-2xl font-bold mb-2 text-center">Create Account</h2>
        <p class="text-gray-400 text-center mb-6 text-sm">Start your intelligent analytics journey</p>
        
        <input type="text" id="regName" class="auth-input" placeholder="Full name" autocomplete="name">
        <input type="email" id="regEmail" class="auth-input" placeholder="Email address" autocomplete="email">
        <input type="password" id="regPassword" class="auth-input" placeholder="Create password" autocomplete="new-password">
        
        <select id="regRole" class="auth-input">
            <option value="user">Team Member</option>
            <option value="admin">Project Admin</option>
        </select>
        
        <button class="auth-btn" onclick="handleRegister()">
            <i class="fas fa-user-plus mr-2"></i> Create Account
        </button>
        
        <div class="auth-switch">
            Already have an account? <span onclick="toggleAuth('login')">Sign in</span>
        </div>
    </div>

    <!-- Forgot Password Form -->
    <div id="forgotForm" class="auth-card hidden">
        <div class="axximum-header justify-center mb-8">
            <div class="logo-icon-container">
                <div class="logo-square"></div>
                <div class="logo-circle"></div>
            </div>
            <div class="brand-text">
                <div class="brand-name">axx<span>imum</span></div>
            </div>
        </div>
        
        <h2 class="text-2xl font-bold mb-2 text-center">Reset Password</h2>
        <p class="text-gray-400 text-center mb-6 text-sm">Enter your email to receive reset code</p>
        
        <input type="email" id="forgotEmail" class="auth-input" placeholder="Enter your email" autocomplete="email">
        <button class="auth-btn" onclick="handleForgotPassword()">
            <i class="fas fa-paper-plane mr-2"></i> Send Reset Code
        </button>
        
        <div class="auth-switch">
            <span onclick="toggleAuth('login')">Back to Login</span>
        </div>
    </div>

    <!-- Reset Password Form -->
    <div id="resetPasswordForm" class="auth-card hidden">
        <h2 class="text-2xl font-bold mb-2 text-center">Create New Password</h2>
        <p class="text-gray-400 text-center mb-6 text-sm">Enter the code sent to your email</p>
        
        <input type="text" id="resetOTP" class="auth-input" placeholder="Enter 6-digit code" maxlength="6" inputmode="numeric">
        <input type="password" id="newPassword" class="auth-input" placeholder="New password" autocomplete="new-password">
        
        <button class="auth-btn" onclick="verifyResetAndUpdate()">
            <i class="fas fa-save mr-2"></i> Update Password
        </button>
        
        <div class="auth-switch">
            <span onclick="toggleAuth('login')">Back to Login</span>
        </div>
    </div>

    <!-- Email Verification Form -->
    <div id="verifyForm" class="auth-card hidden">
        <h2 class="text-2xl font-bold mb-2 text-center">Verify Email</h2>
        <p class="text-gray-400 text-center mb-4 text-sm">Code sent to: <span id="verifyEmailDisplay" class="text-blue-400"></span></p>
        
        <input type="hidden" id="verifyEmailHidden">
        
        <input type="text" id="regOTP" class="auth-input" placeholder="6-digit code" maxlength="6" inputmode="numeric">
        
        <button class="auth-btn" onclick="verifyRegistrationOTP()">
            <i class="fas fa-check-circle mr-2"></i> Complete Registration
        </button>
        
        <button class="auth-btn secondary" onclick="resendRegistrationOTP()">
            <i class="fas fa-redo mr-2"></i> Resend Code
        </button>
        
        <div class="auth-switch">
            <span onclick="toggleAuth('login')">Back to Login</span>
        </div>
    </div>
</div>

<!-- ================= MAIN DASHBOARD ================= -->
<div id="dashboardSection" class="hidden">
    <!-- Header -->
    <header class="glass-panel sticky top-0 z-50 border-b border-white/10">
        <div class="max-w-[1800px] mx-auto px-6 py-4">
            <div class="flex items-center justify-between flex-wrap gap-4">
                <div class="axximum-header">
                    <div class="logo-icon-container">
                        <div class="logo-square"></div>
                        <div class="logo-circle"></div>
                    </div>
                    <div class="brand-text">
                        <div class="brand-name">axx<span>imum</span></div>
                        <div class="brand-tagline">Where innovation meets intelligence</div>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="live-pill">
                        <div class="pulse-dot"></div>
                        <span>LIVE UPDATES</span>
                    </div>
                    
                    <div id="userControls" class="flex items-center gap-3">
                        <span id="userName" class="text-sm text-gray-300"></span>
                        <button onclick="handleLogout()" class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg text-sm transition">
                            <i class="fas fa-sign-out-alt mr-2"></i>Logout
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Public View Banner -->
    <div id="publicBanner" class="hidden max-w-[1800px] mx-auto px-6 mt-4">
        <div class="public-banner">
            <div class="flex items-center gap-3">
                <i class="fas fa-globe text-blue-400 text-xl"></i>
                <div>
                    <div class="font-semibold">Public View Mode</div>
                    <div class="text-sm text-gray-400">You're viewing real-time updates. Login to upload data.</div>
                </div>
            </div>
            <button onclick="showAuth()" class="btn-primary text-sm">
                Login to Edit
            </button>
        </div>
    </div>

    <!-- Sheet Tabs -->
    <div class="max-w-[1800px] mx-auto">
        <div class="sheet-tabs-bar">
            <div class="sheet-tab active" id="overviewTabBtn" onclick="switchSheet('__overview__')">
                <i class="fas fa-layer-group"></i>
                Overview
            </div>
            <div class="sheet-tab" id="attendanceTabBtn" onclick="switchSheet('__attendance__')">
                <i class="fas fa-user-clock"></i>
                Attendance
            </div>
            <div id="sheetTabsList" class="flex items-center"></div>
            <div id="addSheetBtn" class="add-sheet-btn" onclick="addBlankSheet()">+</div>
        </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-[1800px] mx-auto px-6 py-6">
        
        <!-- AI Analytics Panel with Chat -->
        <div id="aiPanel" class="ai-section hidden">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <div class="ai-badge">
                        <i class="fas fa-robot"></i> AI Analytics Engine
                    </div>
                    <h3 class="text-lg font-bold mt-2">Intelligent Insights & Auto-Detection</h3>
                </div>
                <div class="flex gap-2">
                    <button onclick="refreshAIInsights()" class="text-sm text-blue-400 hover:text-blue-300">
                        <i class="fas fa-sync-alt mr-1"></i> Refresh
                    </button>
                    <button onclick="generateAIChart()" class="text-sm text-green-400 hover:text-green-300">
                        <i class="fas fa-chart-bar mr-1"></i> Auto Chart
                    </button>
                </div>
            </div>
            
            <!-- AI Insights Cards -->
