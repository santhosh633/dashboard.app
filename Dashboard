// ================= AI INSIGHTS =================
function analyzeTimeBasedPerformance(sheet) {
    const dateCol = sheet.columnMap?.date;
    if (!dateCol) return null;
    
    const now = new Date();
    const weekAgo = new Date(now - 7 * 24 * 60 * 60 * 1000);
    const monthAgo = new Date(now - 30 * 24 * 60 * 60 * 1000);
    
    const weeklyStats = {};
    const monthlyStats = {};
    
    sheet.csvData.rows.forEach(row => {
        const date = new Date(row[dateCol]);
        if (isNaN(date)) return;
        
        const user = row[sheet.columnMap.user];
        const status = (row[sheet.columnMap.status] || '').toLowerCase();
        const pages = parseInt(row[sheet.columnMap.page]) || 1;
        
        if (!status.includes('done')) return;
        
        if (date >= weekAgo) {
            weeklyStats[user] = (weeklyStats[user] || 0) + pages;
        }
        if (date >= monthAgo) {
            monthlyStats[user] = (monthlyStats[user] || 0) + pages;
        }
    });
    
    const weeklyTop = Object.entries(weeklyStats).sort((a, b) => b[1] - a[1])[0];
    const monthlyTop = Object.entries(monthlyStats).sort((a, b) => b[1] - a[1])[0];
    
    return {
        weekly: weeklyTop ? { name: weeklyTop[0], pages: weeklyTop[1] } : null,
        monthly: monthlyTop ? { name: monthlyTop[0], pages: monthlyTop[1] } : null
    };
}

function generateAIInsights(sheet) {
    const users = Object.values(sheet.userStats);
    const insights = [];
    
    const topByPages = [...users].sort((a, b) => b.pagesDone - a.pagesDone)[0];
    if (topByPages && topByPages.pagesDone > 0) {
        insights.push({
            icon: 'fa-crown',
            color: 'text-amber-400',
            bg: 'bg-amber-500/10',
            title: 'Top Performer',
            desc: `${topByPages.name} leads with ${topByPages.pagesDone} pages completed`
        });
    }
    
    if (sheet.isR365 && sheet.hasQC) {
        const topQC = [...users].sort((a, b) => b.qcFiles - a.qcFiles)[0];
        if (topQC && topQC.qcFiles > 0) {
            insights.push({
                icon: 'fa-check-double',
                color: 'text-purple-400',
                bg: 'bg-purple-500/10',
                title: 'QC Leader',
                desc: `${topQC.name} processed ${topQC.qcFiles} QC files`
            });
        }
    }
    
    const timeAnalysis = analyzeTimeBasedPerformance(sheet);
    if (timeAnalysis) {
        if (timeAnalysis.weekly) {
            insights.push({
                icon: 'fa-calendar-week',
                color: 'text-green-400',
                bg: 'bg-green-500/10',
                title: 'Weekly Star',
                desc: `${timeAnalysis.weekly.name} completed ${timeAnalysis.weekly.pages} pages this week`
            });
        }
        if (timeAnalysis.monthly && (!timeAnalysis.weekly || timeAnalysis.monthly.name !== timeAnalysis.weekly.name)) {
            insights.push({
                icon: 'fa-calendar-alt',
                color: 'text-blue-400',
                bg: 'bg-blue-500/10',
                title: 'Monthly Champion',
                desc: `${timeAnalysis.monthly.name} leads with ${timeAnalysis.monthly.pages} pages this month`
            });
        }
    }
    
    const avgPages = sheet.counts.users > 0 ? Math.round(sheet.counts.totalPages / sheet.counts.users) : 0;
    if (avgPages > 0) {
        insights.push({
            icon: 'fa-tachometer-alt',
            color: 'text-indigo-400',
            bg: 'bg-indigo-500/10',
            title: 'Team Velocity',
            desc: `Average ${avgPages} pages assigned per member tasks`
        });
    }
    
    if (sheet.columnMap) {
        const detected = Object.entries(sheet.columnMap)
            .filter(([k, v]) => v)
            .map(([k, v]) => `${k}: "${v}"`)
            .join(', ');
        insights.push({
            icon: 'fa-magic',
            color: 'text-pink-400',
            bg: 'bg-pink-500/10',
            title: 'AI Auto-Detection',
            desc: `Detected columns: ${detected}`
        });
    }
    
    state.aiInsights = insights;
    renderAIInsights();
}

function renderAIInsights() {
    const container = document.getElementById('aiInsightsContent');
    if (!container || currentUser?.role === 'public') return;
    
    container.innerHTML = state.aiInsights.map(insight => `
        <div class="insight-card">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-8 h-8 rounded-lg ${insight.bg} flex items-center justify-center">
                    <i class="fas ${insight.icon} ${insight.color}"></i>
                </div>
                <div class="font-semibold text-sm">${sanitizeHTML(insight.title)}</div>
            </div>
            <p class="text-sm text-gray-300">${sanitizeHTML(insight.desc)}</p>
