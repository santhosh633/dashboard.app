}

function handleForgotPassword() {
    const email = document.getElementById('forgotEmail').value.trim().toLowerCase();
    
    if (!email) {
        showToast('Please enter your email', 'error');
        return;
    }
    
    const users = JSON.parse(localStorage.getItem(USERS_KEY) || '[]');
